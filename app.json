{
  "expo": {
    "name": "WhatsLeft Connect",
    "slug": "whatsleft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whatsleft",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WhatsLeft uses your location only when you open the Nearby tab to help you discover people around you. Location access is completely optional and you can disable it at any time.",
        "NSLocationAlwaysUsageDescription": "WhatsLeft only uses location while the Nearby map is open. We never track your location in the background.",
        "NSCameraUsageDescription": "WhatsLeft needs camera access so you can take and upload profile photos.",
        "NSPhotoLibraryUsageDescription": "WhatsLeft needs access to your photo library so you can choose a profile picture."
      }
    },
    "android": {
      "package": "com.akash.whatsleft",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCHLOyFkpU-Y_WiBweFtRw0K81zND1sAyI"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#1a1729",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAdiRegistration",
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "WhatsLeft uses your location only on the Nearby tab to show you people nearby. Your location is never shared without your permission and is only active while you have the map open.",
          "locationWhenInUsePermission": "WhatsLeft uses your location only when you visit the Nearby tab. This is optional — you can use all other features without enabling location."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f0c29",
          "dark": {
            "backgroundColor": "#0f0c29"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86b54df8-5c21-4a43-b4b7-e1c78a0ac5c1"
      }
    }
  }
}