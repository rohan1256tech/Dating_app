# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Secret env files — never commit real credentials
.env
!.env.example
backend/.env
!backend/.env.example

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Firebase config files (contain sensitive project info)
google-services.json
GoogleService-Info.plist
