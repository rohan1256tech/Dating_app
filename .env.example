# Environment variables for Expo
# Rename this file to .env and update with your values

# Backend API URL
# For local development on physical device, use your computer's local IP
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# For emulator, you can use: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000 (Android)
EXPO_PUBLIC_API_URL=http://localhost:3000
